# ==============================================================================
# DEPENDÊNCIAS (Nunca devem ir para o repositório)
# ==============================================================================
node_modules/
jspm_packages/
web_modules/

# ==============================================================================
# ARQUIVOS DE CONFIGURAÇÃO LOCAL E SEGURANÇA (Chaves de API e Variáveis de Ambiente)
# ==============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local
# Ignora arquivos de chaves ou certificados locais
*.pem
*.key

# ==============================================================================
# PASTAS DE COMPILAÇÃO / PRODUÇÃO (Geradas automaticamente no build)
# ==============================================================================
dist/
build/
.next/
out/
.nuxt/
.output/
.vuepress/dist/
.docusaurus/

# ==============================================================================
# LOGS E CACHES (Arquivos temporários do sistema e de ferramentas)
# ==============================================================================
# Logs do Node/npm/Yarn
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Caches de ferramentas de qualidade de código
.eslintcache
.stylelintcache
.tsbuildinfo
.vite/
.parcel-cache/
.turbo/

# Cobertura de testes (Jest, Vitest, Cypress)
coverage/
.nyc_output/
.cypress-cache/

# ==============================================================================
# SISTEMAS OPERACIONAIS E EDITORES (Configurações pessoais da sua máquina)
# ==============================================================================
